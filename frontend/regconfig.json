{
  "core": {
    "workingDir": ".reg",
    "actualDir": ".reg/actual",
    "thresholdRate": 0.01,
    "ximgdiff": {
      "invocationType": "client"
    }
  },
  "plugins": {
    "reg-keygen-git-hash-plugin": true,
    "reg-publish-s3-plugin": {
      "bucketName": "REPLACE_WITH_YOUR_BUCKET_NAME"
    },
    "reg-notify-github-plugin": {
      "prComment": true
    }
  }
}
